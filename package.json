{
  "name": "@theyahia/elma365-mcp",
  "version": "1.1.0",
  "description": "MCP server for ELMA365 — BPM, low-code app items (Russia)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "elma365-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/elma365-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "russian-api",
    "elma365",
    "bpm",
    "low-code",
    "streamable-http",
    "api",
    "typescript",
    "crm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/elma365-mcp.git"
  },
  "homepage": "https://github.com/theYahia/elma365-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
}
